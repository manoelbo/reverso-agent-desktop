# Inspirações (projetos de referência): uso local e indexação no Cursor; não versionar.
.agents/inspirations/

# Agent lab filesystem: gerado em runtime. Só versionamos código + PDFs em source para testes na nuvem.
lab/agent/filesystem/*
#!lab/agent/filesystem/source/
#!lab/agent/filesystem/source/*
#!lab/agent/filesystem/source/*.pdf
#!lab/agent/filesystem/source/README.md

# Limpeza para repositório público (mantidos localmente)
.agents/
.claude/
.cursor/
.vscode/
AGENTS.md

# Artefatos e laboratórios não publicados
output_examples/
lab/storybook/

# Imagens de protótipo/teste (não essenciais ao runtime)
chatpanel-zero-*.png
storybook-variant-*.png

# Workspace runtime (base reset versionada apenas com placeholders)
sources/**
dossier/**
investigation/**
events/**
reports/**
sessions/**
!sources/.gitkeep
!dossier/.gitkeep
!investigation/.gitkeep
!events/.gitkeep
!reports/.gitkeep
!sessions/.gitkeep

# Agent GUI runtime filesystems (manter apenas estrutura)
lab/agent-gui/filesystem/**
lab/agent-gui/filesystem_test/**
!lab/agent-gui/filesystem/.gitkeep
!lab/agent-gui/filesystem_test/.gitkeep

# Artefatos locais do agent-cli (não publicar)
lab/agent-cli/*.tgz
lab/agent-cli/.claude/settings.local.json

# Estado local de aprendizagem contínua
.cursor/hooks/state/continual-learning.json
.cursor/hooks/state/continual-learning-index.json