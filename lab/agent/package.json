{
  "name": "agent-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Laboratorio isolado do agente investigativo Reverso",
  "scripts": {
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "init": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts init",
    "agent": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts agent",
    "agent-setup": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts agent-setup",
    "deep-dive": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts deep-dive",
    "dig": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts dig",
    "deep-dive-next": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts deep-dive-next",
    "create-lead": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts create-lead",
    "inquiry": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts inquiry",
    "doc-process": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process",
    "source:process-all": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process process-all --source lab/agent/filesystem/source",
    "source:process-selected": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process process-selected --source lab/agent/filesystem/source",
    "source:process-queue": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process process-queue --source lab/agent/filesystem/source",
    "source:queue-status": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process queue-status --source lab/agent/filesystem/source",
    "source:queue-clear": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process queue-clear --source lab/agent/filesystem/source",
    "source:rerun": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process rerun --all --source lab/agent/filesystem/source",
    "source:rerun-deep": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process rerun --mode deep --all --source lab/agent/filesystem/source",
    "source:watch": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process watch --source lab/agent/filesystem/source",
    "test": "node ../../node_modules/tsx/dist/cli.mjs --test tests/**/*.test.ts",
    "serve": "node ../../node_modules/tsx/dist/cli.mjs src/server/index.ts",
    "serve:test": "AGENT_FILESYSTEM_DIR=filesystem_test AGENT_TEST_MODE=true node ../../node_modules/tsx/dist/cli.mjs src/server/index.ts",
    "reset:chat": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/reset-test.ts chat",
    "reset:investigation": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/reset-test.ts investigation",
    "reset:sources-artefacts": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/reset-test.ts sources-artefacts",
    "reset:all": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/reset-test.ts all",
    "init:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts init",
    "agent:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts agent",
    "dig:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts dig",
    "deep-dive:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts deep-dive",
    "deep-dive-next:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts deep-dive-next",
    "create-lead:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts create-lead",
    "inquiry:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts inquiry",
    "doc-process:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process",
    "source:process-all:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process process-all --source lab/agent/filesystem_test/source",
    "source:process-queue:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process process-queue --source lab/agent/filesystem_test/source",
    "source:rerun:test": "AGENT_FILESYSTEM_DIR=filesystem_test node ../../node_modules/tsx/dist/cli.mjs src/index.ts doc-process rerun --all --source lab/agent/filesystem_test/source"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  }
}
