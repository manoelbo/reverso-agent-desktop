#
# Copy this file to `.env.local` and fill in your values.
# The desktop app and local CLI flows read from the project root env files.
#

# Required: OpenRouter API key used by the investigation agent.
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: default LLM model for agent flows.
AGENT_LAB_MODEL=google/gemini-2.5-flash

# Optional: only needed if you use premium shadcnblocks integration.
SHADCNBLOCKS_API_KEY=your_shadcnblocks_api_key
